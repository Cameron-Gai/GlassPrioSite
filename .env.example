# ServiceTitan integration (server-only) — BOOKINGS FLOW
#
# One POST creates a Booking on ServiceTitan's Job Booking screen; a CSR
# converts it there (ST's native workflow handles customer dedupe, location
# creation, job booking, and scheduling). Nothing else is written by us.
#
# Leave any REQUIRED var unset to keep /api/intake in mock mode (returns
# GLASS-NNNNNN without touching ServiceTitan).

# 'integration' for sandbox testing, 'production' for live.
# Defaults to 'integration' if omitted. Credentials are environment-specific.
SERVICETITAN_ENVIRONMENT=integration

# Required — tenant ID for your ServiceTitan instance.
SERVICETITAN_TENANT_ID=

# Required — app key from your ServiceTitan developer portal application.
SERVICETITAN_APP_KEY=

# Required — OAuth client credentials.
SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=

# Required — numeric Booking Provider Tag ID. One-time setup in the ST UI:
#   Settings → Integrations → Booking Provider Tags → create one
#   (e.g. "Glass Intake Site"), then read its ID via
#   GET /crm/v2/tenant/{tenant}/booking-provider-tags
SERVICETITAN_BOOKING_PROVIDER_ID=

# Optional — numeric Campaign ID for attribution (e.g. a "Web intake"
# campaign). Bookings accept a null campaign; the CSR can attribute at
# conversion. Find via GET /marketing/v2/.../campaigns or ST → Marketing.
SERVICETITAN_CAMPAIGN_ID=

# Optional — JSON map of customer-facing job type name → ServiceTitan Job
# Type ID. When present, the booking is pre-filled with the right job type so
# the CSR doesn't pick it manually. Find IDs via GET /jpm/v2/.../job-types.
# Example:
#   SERVICETITAN_JOB_TYPE_IDS='{"Priority Service (Business Hours)":1234,"Glass Replacement (1-4 Panes) - Consultation":5678}'
SERVICETITAN_JOB_TYPE_IDS=

# Optional — set to '0' to stop sending the on-site charge / Stripe payment id as
# structured `externalData` on the booking (the same info always stays in the
# booking summary). Leave unset/'1' to include it. Verify your tenant's bookings
# endpoint accepts externalData in integration before relying on it.
SERVICETITAN_BOOKING_EXTERNALDATA=1

# =============================================================================
# On-site charge (OSC) — fee lookup + Stripe collection
# =============================================================================
# The intake site resolves the OSC for the customer's ZIP + job type from the
# GlassReports Zone & Charge map, then collects it via Stripe before booking.
# Leave the Stripe keys unset to disable collection (the booking still goes
# through; the office collects at scheduling). Leave the GlassReports vars unset
# to skip fee lookup entirely (every request books with no charge).

# GlassReports base URL (no trailing slash), environment-matched.
#   integration -> your GlassReports integration deployment
#   production  -> your GlassReports production deployment
GLASSREPORTS_BASE_URL=

# Shared secret — must EXACTLY match ZONE_MAP_QUOTE_TOKEN set in GlassReports.
ZONE_MAP_QUOTE_TOKEN=

# Stripe keys (use test keys in integration, live keys in production).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
