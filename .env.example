# ServiceTitan integration (server-only)
#
# Leave any required var unset to keep /api/intake in mock mode (returns
# GLASS-NNNNNN without touching ServiceTitan). When ALL required vars are
# present, the endpoint creates Customer → Location → Job → (hold) in your
# tenant.

# Which ServiceTitan environment to hit. 'integration' for sandbox testing,
# 'production' for live. Defaults to 'integration' if omitted.
# Name matches the GlassReports project (Railway shares the env screen).
SERVICETITAN_ENVIRONMENT=integration

# Required — tenant ID for your ServiceTitan instance.
SERVICETITAN_TENANT_ID=

# Required — app key from your ServiceTitan developer portal application.
SERVICETITAN_APP_KEY=

# Required — OAuth client credentials. These ARE environment-specific
# (integration credentials don't work in production and vice versa).
SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=

# Required — numeric Business Unit ID intake jobs file under.
# Find at Settings → Operations → Business Units (or hit GET /settings/v2/.../business-units).
SERVICETITAN_BUSINESS_UNIT_ID=

# Required — numeric Campaign ID for attribution. The Jobs API returns 400 in
# this tenant if campaignId is missing on create (production-verified). Create
# or pick an existing "Web intake" campaign in ST → Marketing.
SERVICETITAN_CAMPAIGN_ID=

# Required — numeric Hold Reason ID. We hold every intake-created job
# immediately so the placeholder appointment never triggers a customer
# notification before dispatch reviews. Pick "Needs review" or
# "Waiting for materials" via GET /jpm/v2/.../job-hold-reasons.
SERVICETITAN_HOLD_REASON_ID=

# Required — numeric Tag Type ID applied to every job this tool creates or
# touches. Operations standard: the "Automatic, Please Review" tag — same one
# GlassReports' estimate automation uses, so dispatchers can filter all
# auto-created work in one place.
# Find via GET /settings/v2/.../tag-types, or:
#   ServiceTitan → Settings → Tags → Tag Types.
SERVICETITAN_REVIEW_TAG_ID=

# Optional — override the job-type ID map without editing source.
# JSON map of customer-facing job type name → ServiceTitan Job Type ID.
# Example:
#   SERVICETITAN_JOB_TYPE_IDS='{"Priority Service (Business Hours)":1234,"Glass Replacement (1-4 Panes) - Consultation":5678}'
SERVICETITAN_JOB_TYPE_IDS=
